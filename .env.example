# ── Required ─────────────────────────────────────────────────────────────────
# Get your free API key at https://console.groq.com
GROQAPI=your_groq_api_key_here

# ── Notifications (ntfy.sh) ─────────────────────────────────────────────────
# Install the ntfy app on your phone: https://ntfy.sh
# Pick unique topic names (they act as channels)
NTFY_INBOX_TOPIC=your-unique-inbox-topic
NTFY_UPDATE_TOPIC=your-unique-updates-topic

# ── Optional ─────────────────────────────────────────────────────────────────
# LLM model (default: llama-3.3-70b-versatile)
# LLM_MODEL=llama-3.3-70b-versatile

# Directory where projects are created (default: ~/Desktop/Projects)
# PROJECTS_DIR=/home/you/Desktop/Projects

# Open VS Code after project creation (default: true)
# HOOK_OPEN_VSCODE=true

# Web dashboard port (default: 8745)
# WEB_PORT=8745

# Command execution timeout in seconds (default: 120)
# DEFAULT_COMMAND_TIMEOUT=120

# Timeout for heavy commands like npx create-next-app (default: 300)
# HEAVY_COMMAND_TIMEOUT=300
